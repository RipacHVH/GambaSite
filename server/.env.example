# ── Odds API ──────────────────────────────────────────────────
# Free key: https://the-odds-api.com (500 requests/month free)
ODDS_API_KEY=

# ── Server ────────────────────────────────────────────────────
PORT=8787

# Production: restrict CORS to your Vercel frontend URL
ALLOWED_ORIGIN=

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── SQLite ────────────────────────────────────────────────────
# Optional: override the default ./data.db path
# On Render, set this to a path on a persistent disk, e.g. /var/data/calcobetai.db
DB_PATH=

# ── Stripe ────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
# The recurring price ID for your $20/mo product
STRIPE_PRICE_ID=price_...
# From Stripe Dashboard > Developers > Webhooks > signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
