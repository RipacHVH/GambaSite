{
  "name": "edgefinder-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n web,api -c green,magenta \"npm run dev\" \"npm run server\"",
